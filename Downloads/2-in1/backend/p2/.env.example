# Server Configuration
PORT=5000
FLASK_DEBUG=true

# Database (Leave empty to use SQLite default)
DATABASE_URL=

# Security
JWT_SECRET=change_this_secret_locally
SETTINGS_ENCRYPTION_KEY=change_this_local_settings_key
# Generate hashes with: make bootstrap-auth
CLIENTS_AREA_PASSWORD=
OPERATOR_PASSWORD=

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# External Services (Optional for local dev)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
GOOGLE_DEFAULT_COOKIE=
