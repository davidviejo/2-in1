# ---- App ----
# Public name shown in the UI (safe to expose client-side).
NEXT_PUBLIC_APP_NAME="AI Visibility"

# ---- Supabase Postgres ----
# Use the Pooler URL for runtime connections and the direct DB URL for Prisma migrations.
# Replace values with your Supabase project credentials.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=public"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"

# ---- Live analysis providers ----
# OpenAI (ChatGPT analysis mode)
OPENAI_API_KEY=""
OPENAI_DEFAULT_MODEL="gpt-4.1-mini"

# Google Gemini (Gemini analysis mode)
GEMINI_API_KEY=""
GEMINI_DEFAULT_MODEL="gemini-2.5-pro"

# DataForSEO (Google AI Mode + AI Overview analysis modes)
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
DATAFORSEO_LOCATION_CODE="2840"
