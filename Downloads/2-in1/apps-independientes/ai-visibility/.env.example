# ---- App ----
# Public name shown in the UI (safe to expose client-side).
NEXT_PUBLIC_APP_NAME="AI Visibility"

# ---- Local PostgreSQL (docker-compose) ----
# These values are used by docker-compose to create the local database.
POSTGRES_DB="ai_visibility"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_PORT="5432"

# Prisma connection string used by the app and CLI.
# Keep host as localhost when running Next.js on your machine.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_visibility?schema=public"
