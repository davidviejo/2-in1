{
  "name": "ai-visibility",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d postgres",
    "dev:local": "npm run db:up && npx prisma generate && next dev",
    "test:smoke": "vitest run __tests__/smoke.test.ts",
    "test:kpi": "vitest run __tests__/kpi.logic.test.ts",
    "verify": "node scripts/verify.mjs",
    "db:seed": "node scripts/seed-dev.mjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.33",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.33",
    "postcss": "^8.5.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
